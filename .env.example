# Copiar a .env y rellenar (no commitear .env)

# Twilio WhatsApp (requerido para POST /api/notification/*)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Ejemplo sandbox: whatsapp:+14155238886
TWILIO_WHATSAPP_FROM=
# Opcional (MG…): si usas Messaging Service, Twilio lo documenta junto a ContentSid.
# TWILIO_MESSAGING_SERVICE_SID=
# Nota WhatsApp: el campo "text" (mensaje libre) falla con Twilio 63016 si el usuario no te escribió en las últimas 24 h. En producción usa siempre plantillas (contentSid) vía /send, /conductor o /cliente.

# Plantillas (Content SID). notificaciones_de_ruta = solo variable {{1}} nombre de ruta.
# TWILIO_TEMPLATE_ROUTE_ASSIGN=HXb3f55276067d464b8d8e457478e122be
# TEMPLATE_NOTIFICACIONES_DE_RUTA=HXb3f55276067d464b8d8e457478e122be  (alias)
# Plantilla cliente (Svelte): p. ej. corpcopy_va_en_camino — {{1}} cliente, {{2}} conductor
# TWILIO_TEMPLATE_CLIENT_NOTIFY=HX8634c5ceed46670f40c129c9d1623485
# Si la plantilla de cliente solo tiene {{1}} (error Twilio 21656 con dos variables), usar:
# TWILIO_CLIENT_NOTIFY_VARS=1
# (equivale a TWILIO_CLIENT_NOTIFY_SINGLE_VAR=1; envía un solo texto: cliente + negocio.)

# México: por defecto números a +521… (52+1+10 dígitos). Para el formato antiguo +52… poner:
# WHATSAPP_MX_USE_LEGACY_52=1

PORT=3001
