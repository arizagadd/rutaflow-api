generator client {
        provider = "prisma-client-js"
}

datasource db {
        provider = "mysql"
        url      = env("DATABASE_URL")
}

model checklist {
        id_checklist    Int               @id
        item            String?           @db.VarChar(100)
        id_client       Int
        client          client            @relation(fields: [id_client], references: [id_client], onDelete: NoAction, onUpdate: NoAction, map: "fk_checklist_client1")
        checklist_event checklist_event[]

        @@index([id_client], map: "fk_checklist_client1_idx")
}

model checklist_event {
        id_checklist_event Int       @id
        id_checklist       Int
        id_route           Int
        img                String?   @db.VarChar(100)
        checklist          checklist @relation(fields: [id_checklist], references: [id_checklist], onDelete: NoAction, onUpdate: NoAction, map: "fk_checklist_event_checklist1")
        route              route     @relation(fields: [id_route], references: [id_route], onDelete: NoAction, onUpdate: NoAction, map: "fk_checklist_event_route1")

        @@index([id_checklist], map: "fk_checklist_event_checklist1_idx")
        @@index([id_route], map: "fk_checklist_event_route1_idx")
}

model client {
        id_client            Int         @id
        id_company           Int
        name                 String?     @db.VarChar(200)
        contract_description String?     @db.VarChar(45)
        pickup_time          Int?
        delivery_time        Int?
        checklist            checklist[]
        enterprise           enterprise  @relation(fields: [id_company], references: [id_enterprise], onDelete: NoAction, onUpdate: NoAction, map: "fk_client_company1")
        route                route[]
        stop                 stop[]

        @@index([id_company], map: "fk_client_company1_idx")
}

model cms_menu {
        id_cms_menu Int           @id @default(autoincrement())
        titulo      String        @db.VarChar(100)
        tabla       String        @db.VarChar(100)
        grupo       String?       @db.VarChar(100)
        icon        String?       @db.VarChar(100)
        descripcion String?       @db.VarChar(500)
        tipo        String        @default("catalogo") @db.VarChar(100)
        listado     String        @db.Text
        campos      String        @db.Text
        search      CmsMenuSearch
        // search      CmsMenuSearch @default(dbgenerated("0"))
        extra       String?       @db.VarChar(500)
        orden       Int
}

model delivery_week {
        id_delivery_week Int                  @id @default(autoincrement())
        week_start       DateTime             @db.Date
        notes            String?              @db.VarChar(500)
        finished         DeliveryWeekFinished
        // finished         DeliveryWeekFinished @default(dbgenerated("0"))
        id_company       Int
        enterprise       enterprise           @relation(fields: [id_company], references: [id_enterprise], onDelete: NoAction, onUpdate: NoAction, map: "fk_delivery_week_company1")

        @@index([id_company], map: "fk_delivery_week_company1_idx")
}

model driver {
        id_driver     Int           @id
        id_user       Int
        id_enterprise Int
        alias         String?       @db.VarChar(45)
        img           String?       @db.VarChar(200)
        status        DriverStatus?
        enterprise    enterprise    @relation(fields: [id_enterprise], references: [id_enterprise], onDelete: NoAction, onUpdate: NoAction, map: "fk_driver_enterprise1")
        user          user          @relation(fields: [id_user], references: [id_user], onDelete: NoAction, onUpdate: NoAction, map: "fk_driver_user")
        route         route[]

        @@index([id_enterprise], map: "fk_driver_enterprise1_idx")
        @@index([id_user], map: "fk_driver_user_idx")
}

model enterprise {
        id_enterprise                    Int                  @id @default(autoincrement())
        name                             String?              @db.VarChar(100)
        id_owner                         Int
        components                       String?              @db.VarChar(45)
        description                      String?              @db.VarChar(45)
        objective                        EnterpriseObjective?
        settings                         String?              @db.VarChar(1000)
        client                           client[]
        delivery_week                    delivery_week[]
        driver                           driver[]
        user_enterprise_id_ownerTouser   user                 @relation("enterprise_id_ownerTouser", fields: [id_owner], references: [id_user], onDelete: NoAction, onUpdate: NoAction, map: "fk_company_user1")
        route                            route[]
        route_template                   route_template[]
        user_user_id_companyToenterprise user[]               @relation("user_id_companyToenterprise")
        vehicle                          vehicle[]

        @@index([id_owner], map: "fk_company_user1_idx")
}

model event {
        id_event          Int                  @id
        id_route          Int
        id_stop           Int
        status            EventStatus?
        date_route        DateTime?            @db.DateTime(0)
        date_service      DateTime?            @db.DateTime(0)
        date_completed    DateTime?            @db.DateTime(0)
        service_time      Int?
        driver_comments   String?              @db.VarChar(1000)
        eta               DateTime?            @db.DateTime(0)
        id_driver         Int?
        priority_status   EventPriorityStatus? @default(NORMAL)
        order             Int?
        km                Decimal?             @db.Decimal(10, 2)
        logistic_comments String?              @db.VarChar(1000)
        pos               Int?
        route             route                @relation(fields: [id_route], references: [id_route], onDelete: NoAction, onUpdate: NoAction, map: "fk_event_route1")
        stop              stop                 @relation(fields: [id_stop], references: [id_stop], onDelete: NoAction, onUpdate: NoAction, map: "fk_event_stop1")
        evidence          evidence[]

        @@index([id_route], map: "fk_event_route1_idx")
        @@index([id_stop], map: "fk_event_stop1_idx")
}

model event_template {
        id_event_template Int            @id
        id_route_template Int
        id_stop           Int
        pos               String?        @db.VarChar(45)
        route_template    route_template @relation(fields: [id_route_template], references: [id_route_template], onDelete: NoAction, onUpdate: NoAction, map: "fk_event_template_route_template1")
        stop              stop           @relation(fields: [id_stop], references: [id_stop], onDelete: NoAction, onUpdate: NoAction, map: "fk_event_template_stop1")

        @@index([id_route_template], map: "fk_event_template_route_template1_idx")
        @@index([id_stop], map: "fk_event_template_stop1_idx")
}

model evidence {
        id_evidence Int               @id
        id_event    Int
        img         String?           @db.VarChar(100)
        type        String?           @db.VarChar(45)
        approved    EvidenceApproved?
        event       event             @relation(fields: [id_event], references: [id_event], onDelete: NoAction, onUpdate: NoAction, map: "fk_evidence_event1")

        @@index([id_event], map: "fk_evidence_event1_idx")
}

model log {
        id_log     Int      @id @default(autoincrement())
        id_user    Int
        action     String?  @db.VarChar(100)
        table      String   @db.VarChar(100)
        created_at DateTime @default(now()) @db.DateTime(0)
        data       String?  @db.Text
}

model mc_log {
        id_mc_log     Int       @id @default(autoincrement())
        content       String?   @db.VarChar(1000)
        messages_sent Int?
        type          String?   @db.VarChar(45)
        date_sent     DateTime? @default(now()) @db.DateTime(0)
}

model mc_template {
        id_mc_template Int     @id @default(autoincrement())
        name           String? @db.VarChar(45)
        content        String? @db.VarChar(1000)
        objective      String? @db.VarChar(500)
        filters        String? @db.VarChar(1000)
}

model report {
        id_report   Int     @id @default(autoincrement())
        name        String  @db.VarChar(100)
        description String? @db.VarChar(500)
        alias       String  @db.VarChar(100)
        filter      String? @db.VarChar(100)
        query       String  @db.Text
        extra       String? @db.VarChar(100)
}

model route {
        id_route          Int               @id
        id_enterprise     Int
        id_client         Int
        id_vehicle        Int
        id_driver         Int
        id_route_template Int?
        name              String?           @db.VarChar(200)
        date_start        DateTime?         @db.DateTime(0)
        date_end          DateTime?         @db.DateTime(0)
        polyline          String?           @db.VarChar(2500)
        total_duration    Float?            @db.Float
        total_distance    Float?            @db.Float
        stop_initial      Int?
        stop_final        Int?
        checklist_event   checklist_event[]
        event             event[]
        client            client            @relation(fields: [id_client], references: [id_client], onDelete: NoAction, onUpdate: NoAction, map: "fk_route_client1")
        driver            driver            @relation(fields: [id_driver], references: [id_driver], onDelete: NoAction, onUpdate: NoAction, map: "fk_route_driver1")
        enterprise        enterprise        @relation(fields: [id_enterprise], references: [id_enterprise], onDelete: NoAction, onUpdate: NoAction, map: "fk_route_enterprise1")
        route_template    route_template?   @relation(fields: [id_route_template], references: [id_route_template], onDelete: NoAction, onUpdate: NoAction, map: "fk_route_route_template1")
        vehicle           vehicle           @relation(fields: [id_vehicle], references: [id_vehicle], onDelete: NoAction, onUpdate: NoAction, map: "fk_route_vehicle1")

        @@index([id_client], map: "fk_route_client1_idx")
        @@index([id_driver], map: "fk_route_driver1_idx")
        @@index([id_enterprise], map: "fk_route_enterprise1_idx")
        @@index([id_route_template], map: "fk_route_route_template1_idx")
        @@index([id_vehicle], map: "fk_route_vehicle1_idx")
}

model route_template {
        id_route_template Int              @id @default(autoincrement())
        name              String?          @db.VarChar(45)
        id_driver         Int?
        description       String?          @db.VarChar(45)
        color             String?          @db.VarChar(45)
        symbol            String?          @db.VarChar(45)
        id_company        Int
        stop_initial      Int?
        stop_final        Int?
        event_template    event_template[]
        route             route[]
        enterprise        enterprise       @relation(fields: [id_company], references: [id_enterprise], onDelete: NoAction, onUpdate: NoAction, map: "fk_base_route_company1")
        stop              stop[]

        @@index([id_company], map: "fk_base_route_company1_idx")
}

model stop {
        id_stop        Int              @id @default(autoincrement())
        id_client      Int
        id_base_route  Int?
        type           StopType?
        title          String?          @db.VarChar(200)
        main           StopMain
        schedule       String?          @db.VarChar(200)
        line1          String?          @db.VarChar(200)
        line2          String?          @db.VarChar(200)
        zip            String?          @db.VarChar(45)
        city           String?          @db.VarChar(45)
        time_start     Int?
        time_end       Int?
        lat            Float?
        lon            Float?
        comments       String?          @db.VarChar(200)
        event          event[]
        event_template event_template[]
        route_template route_template?  @relation(fields: [id_base_route], references: [id_route_template], onDelete: NoAction, onUpdate: NoAction, map: "fk_address_base_route1")
        client         client           @relation(fields: [id_client], references: [id_client], onDelete: NoAction, onUpdate: NoAction, map: "fk_address_client1")

        @@index([id_base_route], map: "fk_address_base_route1_idx")
        @@index([id_client], map: "fk_address_client1_idx")
}

model support_log {
        id_support_log Int               @id @default(autoincrement())
        id_subscriber  Int
        action         String?           @db.VarChar(500)
        created_at     DateTime?         @default(now()) @db.DateTime(0)
        delivery_date  DateTime?         @db.DateTime(0)
        solved         SupportLogSolved?
}

model user {
        id_user                                Int          @id @default(autoincrement())
        name                                   String?      @db.VarChar(100)
        type                                   UserType?
        email                                  String?      @db.VarChar(45)
        user                                   String?      @db.VarChar(45)
        pass                                   String?      @db.VarChar(45)
        token                                  String?      @db.VarChar(45)
        phone                                  String?      @db.VarChar(45)
        referral_code                          String?      @db.VarChar(200)
        active                                 UserActive?
        id_company                             Int?
        driver                                 driver[]
        enterprise_enterprise_id_ownerTouser   enterprise[] @relation("enterprise_id_ownerTouser")
        enterprise_user_id_companyToenterprise enterprise?  @relation("user_id_companyToenterprise", fields: [id_company], references: [id_enterprise], onDelete: NoAction, onUpdate: NoAction, map: "fk_user_company1")

        @@index([id_company], map: "fk_user_company1_idx")
}

model vehicle {
        id_vehicle    Int            @id
        id_enterprise Int
        name          String?        @db.VarChar(200)
        img           String?        @db.VarChar(200)
        status        VehicleStatus?
        route         route[]
        enterprise    enterprise     @relation(fields: [id_enterprise], references: [id_enterprise], onDelete: NoAction, onUpdate: NoAction, map: "fk_vehicle_enterprise1")

        @@index([id_enterprise], map: "fk_vehicle_enterprise1_idx")
}

enum UserType {
        SUPER     @map("super")
        ADMIN     @map("admin")
        DRIVER    @map("driver")
        MANAGER   @map("manager")
        LOGISTICS @map("logistics")
        EXTERNAL  @map("external")

        @@map("user_type")
}

enum EventStatus {
        PENDING   @map("pending")
        ROUTE     @map("route")
        ISSUE     @map("issue")
        SERVICE   @map("service")
        COMPLETED @map("completed")

        @@map("event_status")
}

enum StopType {
        VISIT    @map("visit")
        GAS      @map("gas")
        PARKING  @map("parking")
        CEDIS    @map("cedis")
        MAIN     @map("main")
        WORKSHOP @map("workshop")

        @@map("stop_type")
}

enum DeliveryWeekFinished {
        FALSE @map("0")
        TRUE  @map("1")

        @@map("delivery_week_finished")
}

enum EvidenceApproved {
        FALSE @map("0")
        TRUE  @map("1")

        @@map("evidence_approved")
}

enum VehicleStatus {
        AVAILABLE   @map("available")
        WORKSHOP    @map("workshop")
        ROUTE       @map("route")
        UNAVAILABLE @map("unavailable")

        @@map("vehicle_status")
}

enum EnterpriseObjective {
        SUBSCRIPTION @map("subscription")
        LOGISTICS    @map("logistics")
        ECOMMERCE    @map("ecommerce")
        COMPLETE     @map("complete")

        @@map("enterprise_objective")
}

enum StopMain {
        FALSE @map("0")
        TRUE  @map("1")

        @@map("stop_main")
}

enum DriverStatus {
        AVAILABLE   @map("available")
        NODOCS      @map("nodocs")
        UNAVAILABLE @map("unavailable")

        @@map("driver_status")
}

enum SupportLogSolved {
        FALSE @map("0")
        TRUE  @map("1")

        @@map("support_log_solved")
}

enum CmsMenuSearch {
        FALSE @map("0")
        TRUE  @map("1")

        @@map("cms_menu_search")
}

// How it's represented in TSS
enum UserActive {
        FALSE @map("0")
        TRUE  @map("1")

        @@map("user_active") // How it appears in MySQL
}

enum EventPriorityStatus {
        URGENT    @map("urgent")
        NORMAL    @map("normal")
        NOTURGENT @map("noturgent")

        @@map("event_priority_status")
}
