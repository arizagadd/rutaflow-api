# Copiar a .env y rellenar (no commitear .env)

# Twilio WhatsApp (requerido para POST /api/notification/*)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Ejemplo sandbox: whatsapp:+14155238886
TWILIO_WHATSAPP_FROM=

# Opcional: SIDs de plantillas aprobadas en Twilio
# TWILIO_TEMPLATE_ROUTE_ASSIGN=HX...
# TWILIO_TEMPLATE_CLIENT_NOTIFY=HX...

PORT=3001
